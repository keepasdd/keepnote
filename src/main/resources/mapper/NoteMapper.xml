<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.keepasd.knowledgebase.mapper.NoteMapper">

    <select id="pageQuery" resultType="com.keepasd.knowledgebase.entity.Note">
        SELECT * FROM note
        <where>
            user_id = #{userId}
            <if test="keyword != null and keyword != ''">
                AND (title LIKE CONCAT('%', #{keyword}, '%')
                OR content LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="tagId != null">
                AND EXISTS (SELECT 1 FROM note_tag nt WHERE nt.note_id = note.id AND nt.tag_id = #{tagId})
            </if>
            <if test="isFavorite != null">
                AND is_favorite = #{isFavorite}
            </if>
            <if test="dateRange != null and dateRange != ''">
                <choose>
                    <when test="dateRange == 'today'">
                        AND create_time >= CURDATE()
                    </when>
                    <when test="dateRange == 'week'">
                        AND create_time >= DATE_SUB(NOW(), INTERVAL 7 DAY)
                    </when>
                    <when test="dateRange == 'month'">
                        AND create_time >= DATE_SUB(NOW(), INTERVAL 1 MONTH)
                    </when>
                </choose>
            </if>
        </where>
        ORDER BY is_pinned DESC, create_time DESC
    </select>
    <resultMap id="NoteWithTagsMap" type="com.keepasd.knowledgebase.entity.Note">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="categoryId" column="category_id" />
        <result property="title" column="title" />
        <result property="content" column="content" />
        <result property="isFavorite" column="is_favorite" />
        <result property="isPinned" column="is_pinned" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <collection property="tags" ofType="com.keepasd.knowledgebase.entity.Tag">
            <id property="id" column="tag_id" />
            <result property="name" column="tag_name" />
            <result property="color" column="tag_color" />
        </collection>
    </resultMap>

    <select id="getById" resultMap="NoteWithTagsMap">
        SELECT
            n.*,
            t.id    AS tag_id,
            t.name  AS tag_name,
            t.color AS tag_color
        FROM note n
                 LEFT JOIN note_tag nt ON n.id = nt.note_id
                 LEFT JOIN tag t ON nt.tag_id = t.id
        WHERE n.id = #{id}
    </select>

    <insert id="insertNoteTags">
        INSERT INTO note_tag (note_id, tag_id) VALUES
        <foreach collection="tagIds" item="tagId" separator=",">
            (#{noteId}, #{tagId})
        </foreach>
    </insert>

</mapper>
