<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.keepasd.knowledgebase.mapper.CategoryMapper">

    <resultMap id="CategoryWithCount" type="com.keepasd.knowledgebase.entity.Category">
        <id     property="id"         column="id"/>
        <result property="userId"     column="user_id"/>
        <result property="name"       column="name"/>
        <result property="color"      column="color"/>
        <result property="sortOrder"  column="sort_order"/>
        <result property="createTime" column="create_time"/>
        <result property="noteCount"  column="note_count"/>
    </resultMap>

    <select id="selectWithNoteCount" resultMap="CategoryWithCount">
        SELECT c.id, c.user_id, c.name, c.color, c.sort_order, c.create_time,
               COUNT(n.id) AS note_count
        FROM category c
        LEFT JOIN note n ON n.category_id = c.id
        WHERE c.user_id = #{userId}
        GROUP BY c.id
        ORDER BY c.sort_order ASC, c.id ASC
    </select>

</mapper>
