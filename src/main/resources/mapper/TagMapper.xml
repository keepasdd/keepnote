<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.keepasd.knowledgebase.mapper.TagMapper">

    <!-- 查询当前用户所有标签（平铺），用于在内存中组装树形结构 -->
    <select id="selectByUserId" resultType="com.keepasd.knowledgebase.entity.Tag">
        SELECT id, user_id, name, color, parent_id
        FROM tag
        WHERE user_id = #{userId}
        ORDER BY id ASC
    </select>

</mapper>
